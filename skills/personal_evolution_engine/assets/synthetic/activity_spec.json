              "chart": {
                "title": "Сделки и обращения по регионам",
                "category_key": "region",
                "value_keys": ["deals", "leads"],
                "labels": {"deals": "Сделки", "leads": "Обращения"},
                "value_title": "Количество",
                "category_title": "Регион",
                "anchor": "G2"
              }
            }
          }
        }
      ]
    },
    {
      "case_prefix": "day_closing_cycle",
      "occurrences": 16,
