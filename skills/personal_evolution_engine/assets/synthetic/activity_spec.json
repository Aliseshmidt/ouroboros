    {
      "case_prefix": "partner_mail_cycle",
      "occurrences": 15,
      "start": "2026-06-01T09:10:00+03:00",
      "interval_days": 1,
      "outcome": "таблица по письмам партнёров с отмеченными пропусками",
      "steps": [
        {
          "application": "Почта",
          "action": "прочитать входящие данные",
          "object_type": "письма партнёров",
          "activity": "открыть письма партнёров и выписать показатели",
          "duration_min": 5.2,
          "automation_share": 0.9,
          "effect": "read",
          "automation": {
            "operation": "load_json",
            "settings": {
              "glob": "inbox/partner_messages/*.json",
              "save_as": "partner_messages"
            }
          }
        },
        {
          "application": "Excel",
          "action": "перенести поля",
          "object_type": "строки партнёрского отчёта",
          "activity": "перенести нужные поля в таблицу",
          "duration_min": 8.5,
          "automation_share": 0.92,
          "effect": "sandbox",
          "automation": {
            "operation": "select_fields",
            "settings": {
              "from": "partner_messages",
              "save_as": "partner_rows",
              "fields": ["partner", "report_date", "region", "orders", "revenue", "comment"]
            }
          }
        },
        {
          "application": "Excel",
          "action": "проверить и сохранить копию",
          "object_type": "итоговая таблица партнёров",
          "activity": "подсветить пропуски и сохранить файл для проверки",
          "duration_min": 4.4,
          "automation_share": 0.78,
          "effect": "sandbox",
          "automation": {
            "operation": "write_excel",
            "settings": {
              "from": "partner_rows",
              "filename": "partner_mail_summary.xlsx",
              "sheet": "Партнёры",
              "columns": [
                {"key": "partner", "header": "Партнёр", "required": true},
                {"key": "report_date", "header": "Дата отчёта", "required": true},
                {"key": "region", "header": "Регион", "required": true},
                {"key": "orders", "header": "Заказы", "required": true},
                {"key": "revenue", "header": "Выручка", "required": true, "number_format": "#,##0"},
                {"key": "comment", "header": "Комментарий", "required": false}
              ],
              "chart": {
                "title": "Выручка партнёров",
                "category_key": "partner",
                "value_keys": ["revenue"],
                "category_title": "Партнёр",
                "value_title": "Выручка",
                "anchor": "H2"
              }
            }
          }
        }
      ]
    },
    {
