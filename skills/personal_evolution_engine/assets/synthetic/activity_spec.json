            "operation": "load_csv",
            "settings": {"glob": "reporting/crm_sales.csv", "save_as": "crm_sales"}
          }
        },
        {
          "application": "BI",
          "action": "выгрузить показатели",
          "object_type": "региональные обращения BI",
