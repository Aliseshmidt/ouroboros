          }
        },
        {
          "application": "Excel",
          "action": "обновить отчёт",
          "object_type": "еженедельный отчёт",
          "activity": "обновить таблицу и построить диаграмму",
          "duration_min": 8.7,
          "automation_share": 0.86,
          "effect": "sandbox",
          "automation": {
            "operation": "write_excel",
            "settings": {
              "from": "weekly_summary",
              "filename": "weekly_management_report.xlsx",
              "sheet": "Неделя",
              "columns": [
                {"key": "region", "header": "Регион", "required": true},
                {"key": "deals", "header": "Сделки", "required": true},
                {"key": "revenue", "header": "Выручка", "required": true},
                {"key": "leads", "header": "Обращения", "required": true},
                {"key": "conversion", "header": "Конверсия, %", "required": true, "number_format": "0.0"}
