            "operation": "load_csv",
            "settings": {"glob": "reporting/bi_funnel.csv", "save_as": "bi_funnel"}
          }
        },
        {
          "application": "Excel",
          "action": "свести данные",
          "object_type": "региональная сводка",
          "activity": "сопоставить выгрузки по регионам",
          "duration_min": 12.8,
          "automation_share": 0.9,
          "effect": "sandbox",
          "automation": {
